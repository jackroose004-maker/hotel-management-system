<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Order Cancelled — {{restaurantName}}</title>
</head>
<body style="margin:0;padding:0;background:{{bgColor}};font-family:'Segoe UI',Helvetica,Arial,sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:{{bgColor}};padding:40px 16px;">
    <tr>
      <td align="center">
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;">

          <!-- HEADER -->
          <tr>
            <td style="background:linear-gradient(150deg,#1e293b 0%,#0f172a 100%);border-radius:20px 20px 0 0;padding:36px 40px 28px;text-align:center;">
              {{#if logoUrl}}
                <img src="{{logoUrl}}" alt="{{restaurantName}}" width="48" height="48"
                  style="border-radius:12px;object-fit:cover;display:block;margin:0 auto 14px;opacity:0.7;" />
              {{/if}}
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding-bottom:14px;">
                    <table cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="width:52px;height:52px;background:rgba(239,68,68,0.12);border:1.5px solid rgba(239,68,68,0.3);border-radius:50%;text-align:center;vertical-align:middle;">
                          <span style="font-size:22px;line-height:52px;">✕</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              <p style="margin:0 0 4px;color:rgba(255,255,255,0.45);font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;">
                {{restaurantName}}
              </p>
              <h1 style="margin:0;color:#f1f5f9;font-size:24px;font-weight:800;">Order Cancelled</h1>
              <p style="margin:6px 0 0;color:#94a3b8;font-size:13px;">
                Your order has been cancelled{{#if cancelledByStaff}} by our team{{/if}}
              </p>
            </td>
          </tr>

          <!-- GREETING -->
          <tr>
            <td style="background:#1e293b;border-bottom:1px solid #334155;padding:18px 40px;">
              <p style="margin:0;color:#cbd5e1;font-size:14px;line-height:1.6;">
                Hi <strong style="color:#f1f5f9;">{{name}}</strong> — your order has been cancelled{{#if cancelledByStaff}} by a member of our team{{/if}}. Here's a summary of what was included.
              </p>
            </td>
          </tr>

          <!-- ORDER REF -->
          <tr>
            <td style="background:#1e293b;padding:28px 40px 0;">
              <table width="100%" cellpadding="0" cellspacing="0"
                style="background:rgba(239,68,68,0.07);border:1px solid rgba(239,68,68,0.2);border-radius:12px;margin-bottom:24px;">
                <tr>
                  <td style="padding:14px 20px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td>
                          <p style="margin:0;color:#ef4444;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">Cancelled Order</p>
                        </td>
                        <td align="right">
                          <p style="margin:0;color:#f1f5f9;font-size:16px;font-weight:900;font-family:monospace;letter-spacing:2px;">#{{ref}}</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- ORDER ITEMS -->
          {{#if items.length}}
          <tr>
            <td style="background:#1e293b;padding:0 40px;">
              <p style="margin:0 0 12px;color:#64748b;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Items Ordered</p>
              <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:0;">
                {{#each items}}
                <tr>
                  <td style="padding:10px 0;border-bottom:1px solid #334155;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td>
                          <p style="margin:0;color:#cbd5e1;font-size:14px;">
                            <span style="color:#64748b;">×{{quantity}}</span>&nbsp; {{name}}
                          </p>
                        </td>
                        <td align="right">
                          <p style="margin:0;color:#94a3b8;font-size:14px;">AED {{amount}}</p>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                {{/each}}
                <tr>
                  <td style="padding:14px 0;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td><p style="margin:0;color:#94a3b8;font-size:13px;font-weight:700;">Order Total</p></td>
                        <td align="right"><p style="margin:0;color:#ef4444;font-size:18px;font-weight:900;">AED {{total}}</p></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {{/if}}

          <!-- CANCEL REASON -->
          {{#if cancelReason}}
          <tr>
            <td style="background:#1e293b;padding:0 40px 24px;">
              <p style="margin:0 0 10px;color:#64748b;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Cancellation Reason</p>
              <table width="100%" cellpadding="0" cellspacing="0"
                style="background:#0f172a;border:1px solid #334155;border-radius:12px;">
                <tr>
                  <td style="padding:14px 18px;">
                    <p style="margin:0;color:#94a3b8;font-size:13px;line-height:1.6;">{{cancelReason}}</p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {{/if}}

          <!-- CONTACT -->
          <tr>
            <td style="background:#1e293b;padding:0 40px 28px;">
              <table width="100%" cellpadding="0" cellspacing="0"
                style="background:#0f172a;border:1px solid #334155;border-radius:12px;">
                <tr>
                  <td style="padding:16px 20px;">
                    <p style="margin:0;color:#94a3b8;font-size:13px;line-height:1.7;">
                      Have questions about this cancellation?
                      {{#if supportEmail}}
                        Reach us at <a href="mailto:{{supportEmail}}" style="color:{{brandColor}};text-decoration:none;">{{supportEmail}}</a>{{#if supportPhone}} or call <strong style="color:#e2e8f0;">{{supportPhone}}</strong>{{/if}}.
                      {{else}}
                        Please contact us directly.
                      {{/if}}
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          {{#if footerNote}}
          <tr>
            <td style="background:#1e293b;padding:0 40px 20px;">
              <p style="margin:0;color:#64748b;font-size:12px;text-align:center;line-height:1.6;">{{footerNote}}</p>
            </td>
          </tr>
          {{/if}}

          <!-- SOCIAL -->
          {{#if hasSocial}}
          <tr>
            <td style="background:#0f172a;padding:16px 40px;text-align:center;border-top:1px solid #1e293b;">
              <p style="margin:0 0 10px;color:#475569;font-size:11px;text-transform:uppercase;letter-spacing:1px;">Follow us</p>
              <table cellpadding="0" cellspacing="0" style="margin:0 auto;">
                <tr>
                  {{#if socialInstagram}}<td style="padding:0 6px;"><a href="{{socialInstagram}}" style="color:#94a3b8;text-decoration:none;font-size:11px;">Instagram</a></td>{{/if}}
                  {{#if socialWhatsapp}}<td style="padding:0 6px;"><a href="{{socialWhatsapp}}" style="color:#94a3b8;text-decoration:none;font-size:11px;">WhatsApp</a></td>{{/if}}
                  {{#if socialTelegram}}<td style="padding:0 6px;"><a href="{{socialTelegram}}" style="color:#94a3b8;text-decoration:none;font-size:11px;">Telegram</a></td>{{/if}}
                  {{#if socialTiktok}}<td style="padding:0 6px;"><a href="{{socialTiktok}}" style="color:#94a3b8;text-decoration:none;font-size:11px;">TikTok</a></td>{{/if}}
                  {{#if socialFacebook}}<td style="padding:0 6px;"><a href="{{socialFacebook}}" style="color:#94a3b8;text-decoration:none;font-size:11px;">Facebook</a></td>{{/if}}
                  {{#if socialTwitter}}<td style="padding:0 6px;"><a href="{{socialTwitter}}" style="color:#94a3b8;text-decoration:none;font-size:11px;">Twitter</a></td>{{/if}}
                </tr>
              </table>
            </td>
          </tr>
          {{/if}}

          <!-- FOOTER -->
          <tr>
            <td style="background:#0f172a;border-radius:0 0 20px 20px;padding:18px 40px;text-align:center;border-top:1px solid #1e293b;">
              <p style="margin:0 0 3px;color:rgba(255,255,255,0.25);font-size:11px;">
                © {{year}} {{restaurantName}}. All rights reserved.
              </p>
              <p style="margin:0;color:rgba(255,255,255,0.15);font-size:10px;">
                {{footerNoReplyText}}
                {{#if supportEmail}}&nbsp;·&nbsp;{{supportEmail}}{{/if}}
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
