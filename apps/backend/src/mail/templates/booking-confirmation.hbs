<!DOCTYPE html>
<html lang="en" style="background:{{bgColor}};">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Booking Confirmed — {{restaurantName}}</title>
</head>
<body style="margin:0;padding:0;background:{{bgColor}};font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="background:{{bgColor}};padding:28px 12px;">
<tr><td align="center">
<table width="100%" cellpadding="0" cellspacing="0" style="max-width:520px;">

  <!-- HEADER -->
  <tr>
    <td style="background:linear-gradient(150deg,{{brandColor}} 0%,{{brandColorDark}} 100%);border-radius:16px 16px 0 0;padding:28px 32px 22px;text-align:center;">
      {{#if logoUrl}}<img src="{{logoUrl}}" width="48" height="48" alt="{{restaurantName}}" style="border-radius:12px;display:block;margin:0 auto 12px;object-fit:cover;box-shadow:0 4px 14px rgba(0,0,0,0.3);"/>{{/if}}
      <p style="margin:0 0 4px;color:rgba(255,255,255,0.6);font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;">{{restaurantName}}</p>
      <h1 style="margin:0;color:#fff;font-size:24px;font-weight:800;letter-spacing:-0.3px;">Booking Confirmed ✓</h1>
      <p style="margin:6px 0 0;color:rgba(255,255,255,0.75);font-size:13px;">We look forward to seeing you</p>
    </td>
  </tr>

  <!-- GREETING -->
  <tr>
    <td style="background:#fff;padding:20px 28px 0;">
      <p style="margin:0;color:#4b5563;font-size:14px;line-height:1.65;">Hi <strong style="color:#111;">{{name}}</strong> — your table is locked in.</p>
    </td>
  </tr>

  <!-- REF + DETAILS -->
  <tr>
    <td style="background:#fff;padding:14px 28px 0;">
      <table width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #f0f0f0;border-radius:14px;overflow:hidden;">
        <tr>
          <td style="background:{{brandColor}}0d;padding:11px 16px;border-bottom:1px solid #f0f0f0;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:{{brandColor}};font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">Booking Ref</p></td>
              <td align="right"><p style="margin:0;color:#111;font-size:14px;font-weight:900;font-family:monospace;letter-spacing:2px;">{{ref}}</p></td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:11px 16px;border-bottom:1px solid #f5f5f5;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#9ca3af;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Date</p></td>
              <td align="right"><p style="margin:0;color:#111;font-size:13px;font-weight:700;">{{slotDate}}</p></td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:11px 16px;border-bottom:1px solid #f5f5f5;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#9ca3af;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Time</p></td>
              <td align="right"><p style="margin:0;color:{{brandColor}};font-size:15px;font-weight:900;">{{slotTime}}</p></td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:11px 16px;border-bottom:1px solid #f5f5f5;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#9ca3af;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Table</p></td>
              <td align="right"><p style="margin:0;color:#111;font-size:13px;font-weight:700;">{{tableNumber}}</p></td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:11px 16px;border-bottom:1px solid #f5f5f5;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#9ca3af;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Guests</p></td>
              <td align="right"><p style="margin:0;color:#111;font-size:13px;font-weight:700;">{{partySize}} guest{{#if partySizePlural}}s{{/if}}</p></td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:11px 16px;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#9ca3af;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Seating</p></td>
              <td align="right"><p style="margin:0;color:#111;font-size:13px;font-weight:700;">{{zone}}</p></td>
            </tr></table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- TICKET + GRACE NOTICE -->
  <tr>
    <td style="background:#fff;padding:12px 28px;">
      <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:12px;">
        <tr>
          <td style="padding:13px 16px;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td style="width:28px;vertical-align:middle;font-size:18px;">🎟</td>
              <td style="padding-left:10px;vertical-align:middle;">
                <p style="margin:0 0 2px;color:#111;font-size:12px;font-weight:700;">Booking ticket attached</p>
                <p style="margin:0;color:#9ca3af;font-size:11px;">Scan QR code at entrance to check in instantly.</p>
              </td>
            </tr></table>
          </td>
        </tr>
      </table>
      <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:8px;background:#fffbf0;border:1px solid #fde68a;border-radius:12px;">
        <tr><td style="padding:11px 16px;">
          <p style="margin:0;color:#92400e;font-size:12px;line-height:1.6;">⏱ Arrive within <strong>{{graceMin}} min</strong> of your slot — late arrivals may lose their table.</p>
        </td></tr>
      </table>
    </td>
  </tr>

  {{#if hasPreOrder}}
  <!-- PRE-ORDER -->
  <tr>
    <td style="background:#fff;padding:0 28px 12px;">
      <table width="100%" cellpadding="0" cellspacing="0" style="background:{{brandColor}}08;border:1px solid {{brandColor}}25;border-radius:12px;">
        <tr><td style="padding:14px 18px;">
          <p style="margin:0 0 10px;color:{{brandColor}};font-size:10px;font-weight:800;letter-spacing:2px;text-transform:uppercase;">Pre-Order · Fires on Arrival</p>
          <table width="100%" cellpadding="0" cellspacing="0">
            {{#each preOrderItems}}
            <tr>
              <td style="padding:3px 0;font-size:12px;color:#374151;">{{qty}}× {{name}}</td>
              <td style="padding:3px 0;font-size:12px;font-weight:700;text-align:right;color:#111;">AED {{amount}}</td>
            </tr>
            {{/each}}
          </table>
          <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:8px;border-top:1px solid {{brandColor}}20;">
            <tr>
              <td style="padding-top:8px;font-size:11px;color:#9ca3af;">Total</td>
              <td style="padding-top:8px;font-size:15px;font-weight:900;color:{{brandColor}};text-align:right;">AED {{preOrderTotal}}</td>
            </tr>
          </table>
        </td></tr>
      </table>
    </td>
  </tr>
  {{/if}}

  {{#if newAccount}}
  <!-- NEW ACCOUNT -->
  <tr>
    <td style="background:#fff;padding:0 28px 12px;">
      <table width="100%" cellpadding="0" cellspacing="0" style="background:#0f172a;border-radius:12px;">
        <tr><td style="padding:18px 20px;">
          <p style="margin:0 0 10px;color:rgba(255,255,255,0.4);font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">Your Account</p>
          <table width="100%" cellpadding="0" cellspacing="0">
            <tr><td style="padding-bottom:8px;">
              <p style="margin:0 0 2px;color:rgba(255,255,255,0.3);font-size:10px;text-transform:uppercase;letter-spacing:1px;">Email</p>
              <p style="margin:0;color:#fff;font-size:13px;font-family:monospace;">{{email}}</p>
            </td></tr>
            <tr><td>
              <p style="margin:0 0 2px;color:rgba(255,255,255,0.3);font-size:10px;text-transform:uppercase;letter-spacing:1px;">Temp Password</p>
              <p style="margin:0;color:{{brandColor}};font-size:18px;font-weight:900;font-family:monospace;letter-spacing:3px;">{{tempPassword}}</p>
            </td></tr>
          </table>
        </td></tr>
      </table>
    </td>
  </tr>
  {{/if}}

  <!-- SOCIAL -->
  {{#if hasSocial}}
  <tr>
    <td style="background:#f9fafb;padding:14px 28px;text-align:center;border-top:1px solid #f0f0f0;">
      <p style="margin:0 0 10px;color:#9ca3af;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Follow us</p>
      <table cellpadding="0" cellspacing="0" style="margin:0 auto;"><tr>
        {{#if socialInstagram}}<td style="padding:0 4px;"><a href="{{socialInstagram}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/instagram-new.png" width="32" height="32" alt="Instagram" style="display:block;border-radius:8px;"/></a></td>{{/if}}
        {{#if socialWhatsapp}}<td style="padding:0 4px;"><a href="{{socialWhatsapp}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/whatsapp.png" width="32" height="32" alt="WhatsApp" style="display:block;border-radius:8px;"/></a></td>{{/if}}
        {{#if socialTelegram}}<td style="padding:0 4px;"><a href="{{socialTelegram}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/telegram-app.png" width="32" height="32" alt="Telegram" style="display:block;border-radius:8px;"/></a></td>{{/if}}
        {{#if socialTiktok}}<td style="padding:0 4px;"><a href="{{socialTiktok}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/tiktok.png" width="32" height="32" alt="TikTok" style="display:block;border-radius:8px;"/></a></td>{{/if}}
        {{#if socialFacebook}}<td style="padding:0 4px;"><a href="{{socialFacebook}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/facebook-new.png" width="32" height="32" alt="Facebook" style="display:block;border-radius:8px;"/></a></td>{{/if}}
        {{#if socialTwitter}}<td style="padding:0 4px;"><a href="{{socialTwitter}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/x-2.png" width="32" height="32" alt="X" style="display:block;border-radius:8px;"/></a></td>{{/if}}
      </tr></table>
    </td>
  </tr>
  {{/if}}

  <!-- FOOTER -->
  <tr>
    <td style="background:#111;border-radius:0 0 16px 16px;padding:14px 28px;text-align:center;">
      <p style="margin:0 0 3px;color:rgba(255,255,255,0.3);font-size:11px;">© {{year}} {{restaurantName}}. All rights reserved.</p>
      <p style="margin:0;color:rgba(255,255,255,0.18);font-size:10px;">{{footerNoReplyText}}{{#if supportEmail}} · {{supportEmail}}{{/if}}</p>
    </td>
  </tr>

</table>
</td></tr></table>
</body>
</html>
