<!DOCTYPE html>
<html lang="en" style="background:{{bgColor}};">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Booking Cancelled — {{restaurantName}}</title>
</head>
<body style="margin:0;padding:0;background:{{bgColor}};font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="background:{{bgColor}};padding:28px 12px;">
<tr><td align="center">
<table width="100%" cellpadding="0" cellspacing="0" style="max-width:520px;">

  <!-- HEADER -->
  <tr>
    <td style="background:linear-gradient(150deg,#1a2236 0%,#0d1117 100%);border-radius:16px 16px 0 0;padding:28px 32px 22px;text-align:center;">
      {{#if logoUrl}}<img src="{{logoUrl}}" width="44" height="44" alt="{{restaurantName}}" style="border-radius:11px;display:block;margin:0 auto 14px;object-fit:cover;opacity:0.75;"/>{{/if}}
      <p style="margin:0 0 4px;color:rgba(255,255,255,0.4);font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;">{{restaurantName}}</p>
      <h1 style="margin:0;color:#f1f5f9;font-size:22px;font-weight:800;">Booking Cancelled</h1>
      <p style="margin:6px 0 0;color:#64748b;font-size:13px;">Your reservation has been cancelled{{#if isStaff}} by our team{{/if}}</p>
    </td>
  </tr>

  <!-- GREETING -->
  <tr>
    <td style="background:#151d2e;padding:16px 28px;border-bottom:1px solid #1e2d40;">
      <p style="margin:0;color:#94a3b8;font-size:13px;line-height:1.65;">
        Hi <strong style="color:#e2e8f0;">{{name}}</strong> — we're letting you know that your reservation at <strong style="color:#e2e8f0;">{{restaurantName}}</strong> has been cancelled.
      </p>
    </td>
  </tr>

  <!-- REF + DETAILS -->
  <tr>
    <td style="background:#151d2e;padding:14px 28px;">
      <table width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #1e2d40;border-radius:12px;overflow:hidden;">
        <tr>
          <td style="background:rgba(239,68,68,0.07);padding:11px 16px;border-bottom:1px solid #1e2d40;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#ef4444;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;">Cancelled Booking</p></td>
              <td align="right"><p style="margin:0;color:#f1f5f9;font-size:14px;font-weight:900;font-family:monospace;letter-spacing:2px;">{{ref}}</p></td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:11px 16px;border-bottom:1px solid #1e2d40;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#475569;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Date</p></td>
              <td align="right"><p style="margin:0;color:#cbd5e1;font-size:13px;font-weight:700;">{{slotDate}}</p></td>
            </tr></table>
          </td>
        </tr>
        <tr>
          <td style="padding:11px 16px;">
            <table width="100%" cellpadding="0" cellspacing="0"><tr>
              <td><p style="margin:0;color:#475569;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Time</p></td>
              <td align="right"><p style="margin:0;color:#cbd5e1;font-size:13px;font-weight:700;">{{slotTime}}</p></td>
            </tr></table>
          </td>
        </tr>
      </table>
    </td>
  </tr>

  <!-- CONTACT NOTICE -->
  <tr>
    <td style="background:#151d2e;padding:0 28px 18px;">
      <table width="100%" cellpadding="0" cellspacing="0" style="background:#0d1117;border:1px solid #1e2d40;border-radius:12px;">
        <tr><td style="padding:14px 18px;">
          <p style="margin:0;color:#64748b;font-size:12px;line-height:1.7;">
            If you'd like to rebook or have questions,
            {{#if supportEmail}}contact us at <a href="mailto:{{supportEmail}}" style="color:{{brandColor}};text-decoration:none;">{{supportEmail}}</a>{{/if}}{{#if supportPhone}} or call <strong style="color:#94a3b8;">{{supportPhone}}</strong>{{/if}}.
          </p>
        </td></tr>
      </table>
    </td>
  </tr>

  <!-- SOCIAL -->
  {{#if hasSocial}}
  <tr>
    <td style="background:#0d1117;padding:14px 28px;text-align:center;border-top:1px solid #1e2d40;">
      <p style="margin:0 0 10px;color:#334155;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;">Follow us</p>
      <table cellpadding="0" cellspacing="0" style="margin:0 auto;"><tr>
        {{#if socialInstagram}}<td style="padding:0 4px;"><a href="{{socialInstagram}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/instagram-new.png" width="32" height="32" alt="Instagram" style="display:block;border-radius:8px;opacity:0.9;"/></a></td>{{/if}}
        {{#if socialWhatsapp}}<td style="padding:0 4px;"><a href="{{socialWhatsapp}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/whatsapp.png" width="32" height="32" alt="WhatsApp" style="display:block;border-radius:8px;opacity:0.9;"/></a></td>{{/if}}
        {{#if socialTelegram}}<td style="padding:0 4px;"><a href="{{socialTelegram}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/telegram-app.png" width="32" height="32" alt="Telegram" style="display:block;border-radius:8px;opacity:0.9;"/></a></td>{{/if}}
        {{#if socialTiktok}}<td style="padding:0 4px;"><a href="{{socialTiktok}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/tiktok.png" width="32" height="32" alt="TikTok" style="display:block;border-radius:8px;opacity:0.9;"/></a></td>{{/if}}
        {{#if socialFacebook}}<td style="padding:0 4px;"><a href="{{socialFacebook}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/facebook-new.png" width="32" height="32" alt="Facebook" style="display:block;border-radius:8px;opacity:0.9;"/></a></td>{{/if}}
        {{#if socialTwitter}}<td style="padding:0 4px;"><a href="{{socialTwitter}}" style="text-decoration:none;display:block;"><img src="https://img.icons8.com/color/32/x-2.png" width="32" height="32" alt="X" style="display:block;border-radius:8px;opacity:0.9;"/></a></td>{{/if}}
      </tr></table>
    </td>
  </tr>
  {{/if}}

  <!-- FOOTER -->
  <tr>
    <td style="background:#0d1117;border-radius:0 0 16px 16px;padding:14px 28px;text-align:center;border-top:1px solid #1e2d40;">
      <p style="margin:0 0 3px;color:rgba(255,255,255,0.2);font-size:11px;">© {{year}} {{restaurantName}}. All rights reserved.</p>
      <p style="margin:0;color:rgba(255,255,255,0.12);font-size:10px;">{{footerNoReplyText}}{{#if supportEmail}} · {{supportEmail}}{{/if}}</p>
    </td>
  </tr>

</table>
</td></tr></table>
</body>
</html>
