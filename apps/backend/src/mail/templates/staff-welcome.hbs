<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to the Team</title>
  <style>
    body { margin: 0; padding: 0; background: #0a0a0a; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
    .wrap { max-width: 520px; margin: 40px auto; background: #111; border: 1px solid #222; border-radius: 20px; overflow: hidden; }
    .header { background: linear-gradient(135deg, #c9a96e 0%, #f0c87a 100%); padding: 36px 40px 28px; text-align: center; }
    .header h1 { margin: 0; font-size: 22px; font-weight: 800; color: #0a0a0a; letter-spacing: -0.02em; }
    .header p { margin: 6px 0 0; font-size: 13px; color: rgba(0,0,0,0.6); }
    .body { padding: 32px 40px; }
    .greeting { font-size: 15px; font-weight: 600; color: #f5f5f5; margin-bottom: 12px; }
    .text { font-size: 13px; color: #999; line-height: 1.7; margin-bottom: 24px; }
    .creds { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 14px; padding: 20px 24px; margin-bottom: 24px; }
    .creds-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .creds-row:last-child { margin-bottom: 0; }
    .creds-label { font-size: 11px; font-weight: 600; color: #666; text-transform: uppercase; letter-spacing: 0.06em; }
    .creds-value { font-size: 13px; font-weight: 700; color: #f5f5f5; font-family: monospace; }
    .warning { background: rgba(249,115,22,0.08); border: 1px solid rgba(249,115,22,0.2); border-radius: 10px; padding: 12px 16px; margin-bottom: 24px; }
    .warning p { margin: 0; font-size: 12px; color: #fb923c; line-height: 1.5; }
    .btn { display: block; text-align: center; background: linear-gradient(135deg, #c9a96e, #f0c87a); color: #0a0a0a; text-decoration: none; font-size: 14px; font-weight: 800; padding: 14px 28px; border-radius: 12px; margin-bottom: 24px; }
    .footer { border-top: 1px solid #1e1e1e; padding: 20px 40px; text-align: center; font-size: 11px; color: #444; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="header">
      <h1>Al Manzil</h1>
      <p>Staff Portal Access</p>
    </div>
    <div class="body">
      <p class="greeting">Welcome, {{name}}! 👋</p>
      <p class="text">
        Your staff account has been created. Use the credentials below to sign in to the staff portal for the first time.
      </p>
      <div class="creds">
        <div class="creds-row">
          <span class="creds-label">Email</span>
          <span class="creds-value">{{email}}</span>
        </div>
        <div class="creds-row">
          <span class="creds-label">Temporary Password</span>
          <span class="creds-value">{{tempPassword}}</span>
        </div>
        {{#if roleName}}
        <div class="creds-row">
          <span class="creds-label">Your Role</span>
          <span class="creds-value">{{roleName}}</span>
        </div>
        {{/if}}
      </div>
      <div class="warning">
        <p>🔒 You must set a new password before you can access the portal. Your temporary password expires after first use.</p>
      </div>
      <a href="{{loginUrl}}" class="btn">Sign In to Staff Portal →</a>
      <p class="text" style="font-size:12px;">
        If you didn't expect this email, please contact your manager immediately.
      </p>
    </div>
    <div class="footer">
      &copy; {{year}} Al Manzil Hotel · All rights reserved
    </div>
  </div>
</body>
</html>
