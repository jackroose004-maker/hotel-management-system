generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  STAFF
  USER
  GUEST
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  APPLE_PAY
  GOOGLE_PAY
  CHARGE_TO_ROOM
}

enum TableStatus {
  EMPTY
  OCCUPIED
  BILL_PENDING
  DIRTY
}

enum BillStatus {
  OPEN
  CLOSED
  VOIDED
}

enum NotificationType {
  ORDER_NEW
  ORDER_ACCEPTED
  ORDER_READY
  ORDER_CANCELLED
  BOOKING_CONFIRMED
  BOOKING_REMINDER
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  SYSTEM
}

enum PromoType {
  PERCENT
  FLAT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ARRIVED
  NO_SHOW
  CANCELLED
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  avatarUrl    String?  @map("avatar_url")
  role         Role     @default(GUEST)
  phone        String?
  dietaryTags           String  @default("") @map("dietary_tags")
  notifOrderUpdates     Boolean @default(true) @map("notif_order_updates")
  notifBookingReminders Boolean @default(true) @map("notif_booking_reminders")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  orders          Order[]
  approvedOrders  Order[]  @relation("ApprovedOrders")
  cancelledOrders Order[]  @relation("CancelledOrders")
  bookings        Booking[]
  strike          CustomerStrike?
  favorites       UserFavorite[]
  notifications   Notification[]
  deviceTokens    DeviceToken[]
  activityLogs    ActivityLog[]   @relation("ActivityLogs")
  feedback        Feedback[]
  statusChanges   OrderStatusHistory[] @relation("StatusChanges")
  generatedBills  Bill[]          @relation("GeneratedBills")
  collectedPayments BillPayment[] @relation("CollectedPayments")
  createdPromos   Promo[]         @relation("CreatedPromos")
  promoUsages     PromoUsage[]

  @@map("users")
}

// Proper M2M join table — replaces the comma-string hack
model UserFavorite {
  userId     String   @map("user_id")
  menuItemId String   @map("menu_item_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([userId, menuItemId])
  @@map("user_favorites")
}

// ─────────────────────────────────────────────
// MENU
// ─────────────────────────────────────────────

model MenuCategory {
  id        String   @id @default(uuid())
  name      String
  nameAr    String?  @map("name_ar")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(uuid())
  categoryId   String   @map("category_id")
  name         String
  nameAr       String?  @map("name_ar")
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  imageUrl     String?  @map("image_url")
  isAvailable  Boolean  @default(true) @map("is_available")
  prepTimeMins Int      @default(15) @map("prep_time_mins")
  isSpecialDay Boolean  @default(false) @map("is_special_day")
  specialLabel String?  @map("special_label")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  category       MenuCategory         @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  modifierGroups MenuModifierGroup[]
  favoritedBy    UserFavorite[]

  @@map("menu_items")
}

// e.g. "Size", "Extras", "Spice Level"
model MenuModifierGroup {
  id         String  @id @default(uuid())
  menuItemId String  @map("menu_item_id")
  name       String
  nameAr     String? @map("name_ar")
  required   Boolean @default(false)
  minSelect  Int     @default(0) @map("min_select")
  maxSelect  Int     @default(1) @map("max_select")
  sortOrder  Int     @default(0) @map("sort_order")

  menuItem MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options  MenuModifierOption[]

  @@map("menu_modifier_groups")
}

// e.g. "Large +5 AED", "Extra Cheese +2 AED"
model MenuModifierOption {
  id        String  @id @default(uuid())
  groupId   String  @map("group_id")
  name      String
  nameAr    String? @map("name_ar")
  priceAdd  Decimal @default(0) @db.Decimal(10, 2) @map("price_add")
  isDefault Boolean @default(false) @map("is_default")
  sortOrder Int     @default(0) @map("sort_order")

  group        MenuModifierGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderChoices OrderItemModifier[]

  @@map("menu_modifier_options")
}

// ─────────────────────────────────────────────
// TABLES
// ─────────────────────────────────────────────

model RestaurantTable {
  id          String      @id @default(uuid())
  tableNumber Int         @unique @map("table_number")
  name        String?
  capacity    Int         @default(4)
  status      TableStatus @default(EMPTY)
  qrCode      String?     @unique @map("qr_code")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  orders   Order[]
  bookings Booking[]
  bills    Bill[]

  @@map("restaurant_tables")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String         @id @default(uuid())
  type            OrderType
  tableId         String?        @map("table_id")
  tableSessionId  String?        @map("table_session_id")
  billId          String?        @map("bill_id")
  userId          String?        @map("user_id")
  tokenNumber     Int?           @map("token_number")
  status          OrderStatus    @default(PENDING)
  subtotal        Decimal        @db.Decimal(10, 2)
  vatAmount       Decimal        @db.Decimal(10, 2) @map("vat_amount")
  discountAmount  Decimal        @default(0) @db.Decimal(10, 2) @map("discount_amount")
  total           Decimal        @db.Decimal(10, 2)
  paymentStatus   PaymentStatus  @default(UNPAID) @map("payment_status")
  paymentMethod   PaymentMethod? @map("payment_method")
  notes           String?
  contactPhone    String?        @map("contact_phone")
  promoId         String?        @map("promo_id")
  approvedById    String?        @map("approved_by_id")
  approvedAt      DateTime?      @map("approved_at")
  cancelledById   String?        @map("cancelled_by_id")
  cancelledAt     DateTime?      @map("cancelled_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  table         RestaurantTable?  @relation(fields: [tableId], references: [id])
  bill          Bill?             @relation(fields: [billId], references: [id])
  user          User?             @relation(fields: [userId], references: [id])
  approvedBy    User?             @relation("ApprovedOrders", fields: [approvedById], references: [id])
  cancelledBy   User?             @relation("CancelledOrders", fields: [cancelledById], references: [id])
  promo         Promo?            @relation(fields: [promoId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  feedback      Feedback?
  promoUsage    PromoUsage?
  legacyPayment Payment?

  @@index([tableSessionId])
  @@index([userId, createdAt])
  @@index([status, paymentStatus])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  menuItemId String  @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2) @map("unit_price")
  notes      String?

  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem  MenuItem           @relation(fields: [menuItemId], references: [id])
  modifiers OrderItemModifier[]

  @@map("order_items")
}

// Selected modifier choices per order line item (price snapshot at order time)
model OrderItemModifier {
  id          String  @id @default(uuid())
  orderItemId String  @map("order_item_id")
  optionId    String  @map("option_id")
  name        String  // snapshot — option name may change later
  priceAdd    Decimal @db.Decimal(10, 2) @map("price_add")

  orderItem OrderItem          @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    MenuModifierOption @relation(fields: [optionId], references: [id])

  @@map("order_item_modifiers")
}

// Full trail of every order status transition — powers kitchen SLA reports
model OrderStatusHistory {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  changedById String?      @map("changed_by_id")
  changedAt   DateTime     @default(now()) @map("changed_at")
  note        String?

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation("StatusChanges", fields: [changedById], references: [id])

  @@index([orderId])
  @@map("order_status_history")
}

// ─────────────────────────────────────────────
// BILL  (consolidated invoice for a table session)
// ─────────────────────────────────────────────

model Bill {
  id             String     @id @default(uuid())
  tableSessionId String     @map("table_session_id")
  tableId        String?    @map("table_id")
  status         BillStatus @default(OPEN)
  subtotal       Decimal    @db.Decimal(10, 2)
  vatAmount      Decimal    @db.Decimal(10, 2) @map("vat_amount")
  serviceCharge  Decimal    @default(0) @db.Decimal(10, 2) @map("service_charge")
  discountAmount Decimal    @default(0) @db.Decimal(10, 2) @map("discount_amount")
  total          Decimal    @db.Decimal(10, 2)
  generatedById  String?    @map("generated_by_id")
  printCount     Int        @default(0) @map("print_count")
  closedAt       DateTime?  @map("closed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  table       RestaurantTable? @relation(fields: [tableId], references: [id])
  generatedBy User?            @relation("GeneratedBills", fields: [generatedById], references: [id])
  orders      Order[]
  payments    BillPayment[]

  @@index([tableSessionId])
  @@map("bills")
}

// A bill can be settled across multiple payment methods (split cash+card)
model BillPayment {
  id            String        @id @default(uuid())
  billId        String        @map("bill_id")
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  reference     String?       // stripe intent id, last4, etc.
  collectedById String?       @map("collected_by_id")
  collectedAt   DateTime      @default(now()) @map("collected_at")

  bill        Bill  @relation(fields: [billId], references: [id])
  collectedBy User? @relation("CollectedPayments", fields: [collectedById], references: [id])

  @@index([billId])
  @@map("bill_payments")
}

// Legacy 1:1 payment record (kept for Stripe webhook compatibility)
model Payment {
  id             String        @id @default(uuid())
  orderId        String        @unique @map("order_id")
  stripeIntentId String?       @unique @map("stripe_intent_id")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("AED")
  status         PaymentStatus @default(UNPAID)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─────────────────────────────────────────────
// PROMOS & DISCOUNTS
// ─────────────────────────────────────────────

model Promo {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  type          PromoType
  value         Decimal   @db.Decimal(10, 2)
  minOrderValue Decimal?  @db.Decimal(10, 2) @map("min_order_value")
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  perUserLimit  Int       @default(1) @map("per_user_limit")
  validFrom     DateTime  @map("valid_from")
  validUntil    DateTime? @map("valid_until")
  isActive      Boolean   @default(true) @map("is_active")
  createdById   String?   @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  createdBy User?        @relation("CreatedPromos", fields: [createdById], references: [id])
  usages    PromoUsage[]
  orders    Order[]

  @@map("promos")
}

model PromoUsage {
  id      String   @id @default(uuid())
  promoId String   @map("promo_id")
  userId  String?  @map("user_id")
  orderId String   @unique @map("order_id")
  usedAt  DateTime @default(now()) @map("used_at")

  promo Promo  @relation(fields: [promoId], references: [id])
  user  User?  @relation(fields: [userId], references: [id])
  order Order  @relation(fields: [orderId], references: [id])

  @@index([promoId, userId])
  @@map("promo_usages")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS & PUSH
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Web Push subscription objects / FCM tokens — survive server restarts
model DeviceToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  platform   String   @default("WEB")
  userAgent  String?  @map("user_agent")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─────────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────────

// Immutable append-only audit log
model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actorRole  Role?    @map("actor_role")
  action     String   // e.g. "order.cancel", "menu.price_change", "table.reset"
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("ActivityLogs", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────
// FEEDBACK
// ─────────────────────────────────────────────

model Feedback {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  userId    String?  @map("user_id")
  rating    Int      // 1–5 stars
  comment   String?
  tags      String?  // e.g. "slow_service,cold_food,great_taste"
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@map("feedback")
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id             String        @id @default(uuid())
  customerId     String        @map("customer_id")
  tableId        String?       @map("table_id")
  partySize      Int           @map("party_size")
  slotDate       DateTime      @db.Date @map("slot_date")
  slotTime       String        @map("slot_time")
  slotExpiresAt  DateTime?     @map("slot_expires_at")
  status         BookingStatus @default(PENDING)
  idempotencyKey String        @unique @map("idempotency_key")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  customer User             @relation(fields: [customerId], references: [id])
  table    RestaurantTable? @relation(fields: [tableId], references: [id])

  @@unique([tableId, slotDate, slotTime])
  @@index([customerId, slotDate])
  @@map("bookings")
}

model CustomerStrike {
  id             String    @id @default(uuid())
  customerId     String    @unique @map("customer_id")
  noShowCount    Int       @default(0) @map("no_show_count")
  lastNoShowAt   DateTime? @map("last_no_show_at")
  blockedUntil   DateTime? @map("blocked_until")
  cancelCount24h Int       @default(0) @map("cancel_count_24h")
  isFlagged      Boolean   @default(false) @map("is_flagged")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  customer User @relation(fields: [customerId], references: [id])

  @@map("customer_strikes")
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

// Generated by cron at midnight — fast reads for the analytics dashboard
model DailyReport {
  id              String   @id @default(uuid())
  date            DateTime @unique @db.Date
  totalOrders     Int      @map("total_orders")
  cancelledOrders Int      @default(0) @map("cancelled_orders")
  totalCovers     Int      @default(0) @map("total_covers")
  grossRevenue    Decimal  @db.Decimal(12, 2) @map("gross_revenue")
  vatCollected    Decimal  @db.Decimal(12, 2) @map("vat_collected")
  discountGiven   Decimal  @default(0) @db.Decimal(12, 2) @map("discount_given")
  netRevenue      Decimal  @db.Decimal(12, 2) @map("net_revenue")
  cashRevenue     Decimal  @db.Decimal(12, 2) @map("cash_revenue")
  cardRevenue     Decimal  @db.Decimal(12, 2) @map("card_revenue")
  avgOrderValue   Decimal  @db.Decimal(10, 2) @map("avg_order_value")
  avgPrepTimeMins Decimal? @db.Decimal(6, 2) @map("avg_prep_time_mins")
  avgRating       Decimal? @db.Decimal(3, 2) @map("avg_rating")
  peakHour        Int?     @map("peak_hour")
  topItemId       String?  @map("top_item_id")
  generatedAt     DateTime @default(now()) @map("generated_at")

  @@map("daily_reports")
}

// ─────────────────────────────────────────────
// RESTAURANT CONFIG
// ─────────────────────────────────────────────

model RestaurantSettings {
  id                  String   @id @default(uuid())
  restaurantName      String   @default("Al Manzil") @map("restaurant_name")
  tagline             String?
  phone               String?
  address             String?
  logoUrl             String?  @map("logo_url")
  openTime            String   @default("07:00") @map("open_time")
  closeTime           String   @default("23:00") @map("close_time")
  timezone            String   @default("Asia/Dubai")
  totalTables         Int      @default(10) @map("total_tables")
  defaultCapacity     Int      @default(4) @map("default_capacity")
  vatRate             Decimal  @default(0.05) @db.Decimal(5, 4) @map("vat_rate")
  serviceChargeRate   Decimal  @default(0) @db.Decimal(5, 4) @map("service_charge_rate")
  currency            String   @default("AED")
  currencySymbol      String   @default("AED") @map("currency_symbol")
  defaultPrepTimeMins Int      @default(15) @map("default_prep_time_mins")
  bookingsEnabled     Boolean  @default(true) @map("bookings_enabled")
  slotDurationMins    Int      @default(30) @map("slot_duration_mins")
  walkInBuffer        Int      @default(3) @map("walk_in_buffer")
  peakHoursEnabled    Boolean  @default(true) @map("peak_hours_enabled")
  peakStart           String   @default("19:00") @map("peak_start")
  peakEnd             String   @default("22:00") @map("peak_end")
  noShowWindowOffPeak Int      @default(20) @map("no_show_window_off_peak")
  noShowWindowPeak    Int      @default(5) @map("no_show_window_peak")
  maxBookingDaysAhead Int      @default(7) @map("max_booking_days_ahead")
  requireLoginToBook  Boolean  @default(true) @map("require_login_to_book")
  remindersEnabled    Boolean  @default(false) @map("reminders_enabled")
  reminderMinsBefore  Int      @default(60) @map("reminder_mins_before")
  brandPreset         String   @default("amber") @map("brand_preset")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("restaurant_settings")
}
