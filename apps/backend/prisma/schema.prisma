generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  OWNER
  STAFF
  CUSTOMER
}

enum OrderType {
  DINE_IN
  TAKEAWAY
}

enum OrderStatus {
  PRE_ORDER
  PENDING
  ACCEPTED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  VOID
  REFUND_REQUESTED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  SPLIT
  APPLE_PAY
  GOOGLE_PAY
  CHARGE_TO_ROOM
}

enum TableStatus {
  EMPTY
  OCCUPIED
  BILL_PENDING
  DIRTY
}


enum NotificationType {
  ORDER_NEW
  ORDER_ACCEPTED
  ORDER_READY
  ORDER_CANCELLED
  BOOKING_CONFIRMED
  BOOKING_REMINDER
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  SYSTEM
}

enum PromoType {
  PERCENT
  FLAT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ARRIVED
  NO_SHOW
  CANCELLED
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model StaffRole {
  id          String   @id @default(uuid())
  name        String   @unique
  color       String   @default("#6b7280")
  permissions Json     @default("[]")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("staff_roles")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String?   @map("password_hash")
  googleId     String?   @unique @map("google_id")
  avatarUrl    String?   @map("avatar_url")
  role         Role      @default(CUSTOMER)
  staffRoleId  String?   @map("staff_role_id")
  staffRole    StaffRole? @relation(fields: [staffRoleId], references: [id], onDelete: SetNull)
  isActive     Boolean   @default(true) @map("is_active")
  phone        String?
  dietaryTags           String    @default("") @map("dietary_tags")
  notifOrderUpdates     Boolean   @default(true) @map("notif_order_updates")
  notifBookingReminders Boolean   @default(true) @map("notif_booking_reminders")
  isVerified            Boolean   @default(false) @map("is_verified")
  mustChangePassword    Boolean   @default(false) @map("must_change_password")
  language              String    @default("en") @map("language")
  otpCode               String?   @map("otp_code")
  otpExpiry             DateTime? @map("otp_expiry")
  resetOtpCode          String?   @map("reset_otp_code")
  resetOtpExpiry        DateTime? @map("reset_otp_expiry")
  resetAttemptsToday    Int       @default(0) @map("reset_attempts_today")
  resetAttemptsDate     DateTime? @map("reset_attempts_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  orders          Order[]
  approvedOrders  Order[]  @relation("ApprovedOrders")
  cancelledOrders Order[]  @relation("CancelledOrders")
  settledOrders   Order[]  @relation("SettledOrders")
  bookings        Booking[]
  strike          CustomerStrike?
  favorites       UserFavorite[]
  notifications   Notification[]
  deviceTokens    DeviceToken[]
  activityLogs    ActivityLog[]   @relation("ActivityLogs")
  feedback        Feedback[]
  statusChanges   OrderStatusHistory[] @relation("StatusChanges")
  createdPromos   Promo[]         @relation("CreatedPromos")
  promoUsages     PromoUsage[]
  shifts          Shift[]
  staffFeedback   StaffFeedback[] @relation("RatedStaff")

  @@map("users")
}

model Shift {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  clockIn    DateTime  @default(now()) @map("clock_in")
  clockOut   DateTime? @map("clock_out")
  role       String
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, clockIn])
  @@map("shifts")
}

// Proper M2M join table — replaces the comma-string hack
model UserFavorite {
  userId     String   @map("user_id")
  menuItemId String   @map("menu_item_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([userId, menuItemId])
  @@map("user_favorites")
}

// ─────────────────────────────────────────────
// MENU
// ─────────────────────────────────────────────

model MenuCategory {
  id        String   @id @default(uuid())
  name      String
  nameAr    String?  @map("name_ar")
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  items MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(uuid())
  categoryId   String   @map("category_id")
  name            String
  nameAr          String?  @map("name_ar")
  description     String?
  descriptionAr   String?  @map("description_ar")
  price        Decimal  @db.Decimal(10, 2)
  imageUrl     String?  @map("image_url")
  videoUrl     String?  @map("video_url")
  isAvailable  Boolean  @default(true) @map("is_available")
  prepTimeMins Int      @default(15) @map("prep_time_mins")
  isSpecialDay Boolean  @default(false) @map("is_special_day")
  specialLabel String?  @map("special_label")
  // ASP — "As per Season/Market Price": price varies daily (fresh fish etc).
  // `price` still holds a reference/last-known value for admin display; guests
  // can't self-checkout it — only staff can add it to an order with a live quote.
  isMarketPrice Boolean @default(false) @map("is_market_price")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  category       MenuCategory         @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  modifierGroups MenuModifierGroup[]
  favoritedBy    UserFavorite[]

  @@map("menu_items")
}

// e.g. "Size", "Extras", "Spice Level"
model MenuModifierGroup {
  id         String  @id @default(uuid())
  menuItemId String  @map("menu_item_id")
  name       String
  nameAr     String? @map("name_ar")
  required   Boolean @default(false)
  minSelect  Int     @default(0) @map("min_select")
  maxSelect  Int     @default(1) @map("max_select")
  sortOrder  Int     @default(0) @map("sort_order")

  menuItem MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options  MenuModifierOption[]

  @@index([menuItemId])
  @@map("menu_modifier_groups")
}

// e.g. "Large +5 AED", "Extra Cheese +2 AED"
model MenuModifierOption {
  id        String  @id @default(uuid())
  groupId   String  @map("group_id")
  name      String
  nameAr    String? @map("name_ar")
  priceAdd  Decimal @default(0) @db.Decimal(10, 2) @map("price_add")
  isDefault Boolean @default(false) @map("is_default")
  sortOrder Int     @default(0) @map("sort_order")

  group        MenuModifierGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderChoices OrderItemModifier[]

  @@index([groupId])
  @@map("menu_modifier_options")
}

// ─────────────────────────────────────────────
// TABLES
// ─────────────────────────────────────────────

model RestaurantTable {
  id          String      @id @default(uuid())
  tableNumber Int         @unique @map("table_number")
  name        String?
  capacity    Int         @default(4)
  status      TableStatus @default(EMPTY)
  isActive      Boolean     @default(true) @map("is_active")
  isReservable  Boolean     @default(true) @map("is_reservable")
  zone          String      @default("Indoor")
  qrCode      String?     @unique @map("qr_code")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  orders   Order[]
  bookings Booking[]
  groupMemberships TableGroupMember[]

  @@index([status])                    // table status board / cleanup queries
  @@index([isReservable, isActive])    // booking slot capacity count
  @@map("restaurant_tables")
}

// Party Mode: 2+ tables merged into one combined bill. Open while closedAt is null —
// at most one open group per table (enforced in service logic, not the DB, since a
// partial unique index needs raw SQL). Settling the group pays every unpaid order
// across every member table in one transaction and closes the group.
model TableGroup {
  id          String    @id @default(uuid())
  label       String?   // optional party name, e.g. "Al-Rashid Wedding"
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  closedAt    DateTime? @map("closed_at")

  members TableGroupMember[]

  @@index([closedAt])
  @@map("table_groups")
}

model TableGroupMember {
  id      String @id @default(uuid())
  groupId String @map("group_id")
  tableId String @map("table_id")

  group TableGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  table RestaurantTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([groupId, tableId])
  @@index([tableId])
  @@map("table_group_members")
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id              String         @id @default(uuid())
  type            OrderType
  tableId         String?        @map("table_id")
  tableSessionId  String?        @map("table_session_id")
  userId          String?        @map("user_id")
  stripeIntentId  String?        @unique @map("stripe_intent_id")
  tokenNumber     Int?           @map("token_number")
  bookingId       String?        @map("booking_id")
  status          OrderStatus    @default(PENDING)
  subtotal        Decimal        @db.Decimal(10, 2)
  vatAmount       Decimal        @db.Decimal(10, 2) @map("vat_amount")
  discountAmount   Decimal        @default(0) @db.Decimal(10, 2) @map("discount_amount")
  discountReason   String?        @map("discount_reason")
  splitCashAmount  Decimal?       @db.Decimal(10, 2) @map("split_cash_amount")
  tipAmount        Decimal        @default(0) @db.Decimal(10, 2) @map("tip_amount")
  packingCharge    Decimal        @default(0) @db.Decimal(10, 2) @map("packing_charge")
  total            Decimal        @db.Decimal(10, 2)
  paymentStatus    PaymentStatus  @default(UNPAID) @map("payment_status")
  paymentMethod    PaymentMethod? @map("payment_method")
  notes           String?
  clientIp        String?        @map("client_ip")
  contactPhone    String?        @map("contact_phone")
  promoId         String?        @map("promo_id")
  approvedById    String?        @map("approved_by_id")
  approvedAt      DateTime?      @map("approved_at")
  cancelledById   String?        @map("cancelled_by_id")
  cancelledAt     DateTime?      @map("cancelled_at")
  // Guest cooling hold: order hidden from kitchen/approval until this passes (free-cancel window)
  heldUntil       DateTime?      @map("held_until")
  cancelReason    String?        @map("cancel_reason")
  isRush          Boolean        @default(false) @map("is_rush")
  isVoided        Boolean        @default(false) @map("is_voided")
  voidReason      String?        @map("void_reason")
  voidedById      String?        @map("voided_by_id")
  voidedAt        DateTime?      @map("voided_at")
  settledById     String?        @map("settled_by_id")
  settledAt       DateTime?      @map("settled_at")
  expectedReadyAt DateTime?      @map("expected_ready_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  table         RestaurantTable?  @relation(fields: [tableId], references: [id], onDelete: Restrict)
  booking       Booking?          @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  user          User?             @relation(fields: [userId], references: [id])
  approvedBy    User?             @relation("ApprovedOrders", fields: [approvedById], references: [id], onDelete: SetNull)
  cancelledBy   User?             @relation("CancelledOrders", fields: [cancelledById], references: [id], onDelete: SetNull)
  settledBy     User?             @relation("SettledOrders", fields: [settledById], references: [id], onDelete: SetNull)
  promo         Promo?            @relation(fields: [promoId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  feedback      Feedback?
  staffFeedback StaffFeedback[]
  promoUsage    PromoUsage?

  @@index([tableSessionId])
  @@index([bookingId])
  @@index([userId, createdAt])
  @@index([status, paymentStatus])
  @@index([tableId, paymentStatus])       // table bill / active-orders check
  @@index([tableId, tableSessionId])      // session groupBy per table
  @@index([createdAt])                    // reports: date-range scans
  @@index([paymentStatus])               // refund queue, daily totals
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  menuItemId String  @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2) @map("unit_price")
  notes      String?
  // Offer discount snapshot — offerName/offerAmount kept even if the Offer is later deleted
  offerName   String? @map("offer_name")
  offerAmount Decimal @default(0) @db.Decimal(10, 2) @map("offer_amount") // total AED discount for this line (qty included)

  order     Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem  MenuItem           @relation(fields: [menuItemId], references: [id])
  modifiers OrderItemModifier[]

  @@index([orderId])        // items per order fetch
  @@index([menuItemId])     // menu analytics / popularity
  @@map("order_items")
}

// Selected modifier choices per order line item (price snapshot at order time)
model OrderItemModifier {
  id          String  @id @default(uuid())
  orderItemId String  @map("order_item_id")
  optionId    String  @map("option_id")
  name        String  // snapshot — option name may change later
  priceAdd    Decimal @db.Decimal(10, 2) @map("price_add")

  orderItem OrderItem          @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    MenuModifierOption @relation(fields: [optionId], references: [id])

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

// Full trail of every order status transition — powers kitchen SLA reports
model OrderStatusHistory {
  id          String       @id @default(uuid())
  orderId     String       @map("order_id")
  fromStatus  OrderStatus? @map("from_status")
  toStatus    OrderStatus  @map("to_status")
  changedById String?      @map("changed_by_id")
  changedAt   DateTime     @default(now()) @map("changed_at")
  note        String?

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation("StatusChanges", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_status_history")
}


// ─────────────────────────────────────────────
// PROMOS & DISCOUNTS
// ─────────────────────────────────────────────

model Promo {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  type          PromoType
  value         Decimal   @db.Decimal(10, 2)
  minOrderValue Decimal?  @db.Decimal(10, 2) @map("min_order_value")
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  perUserLimit  Int       @default(1) @map("per_user_limit")
  validFrom     DateTime  @map("valid_from")
  validUntil    DateTime? @map("valid_until")
  isActive      Boolean   @default(true) @map("is_active")
  createdById   String?   @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")

  createdBy User?        @relation("CreatedPromos", fields: [createdById], references: [id])
  usages    PromoUsage[]
  orders    Order[]

  @@map("promos")
}

model PromoUsage {
  id      String   @id @default(uuid())
  promoId String   @map("promo_id")
  userId  String?  @map("user_id")
  orderId String   @unique @map("order_id")
  usedAt  DateTime @default(now()) @map("used_at")

  promo Promo  @relation(fields: [promoId], references: [id])
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order Order  @relation(fields: [orderId], references: [id])

  @@index([promoId, userId])
  @@map("promo_usages")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS & PUSH
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false) @map("is_read")
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Web Push subscription objects / FCM tokens — survive server restarts
model DeviceToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  token      String   @unique
  platform   String   @default("WEB")
  userAgent  String?  @map("user_agent")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─────────────────────────────────────────────
// AUDIT
// ─────────────────────────────────────────────

// Immutable append-only audit log
model ActivityLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actorRole  Role?    @map("actor_role")
  action     String   // e.g. "order.cancel", "menu.price_change", "table.reset"
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation("ActivityLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────
// FEEDBACK
// ─────────────────────────────────────────────

model Feedback {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  userId    String?  @map("user_id")
  rating    Int      // 1–5 stars
  comment   String?
  tags      String?  // e.g. "slow_service,cold_food,great_taste"
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])    // reports date-range scan
  @@map("feedback")
}

// Guest rates the staff member who served their table — separate from the
// overall meal Feedback above. One per order; staffId is resolved server-side
// (whoever settled the bill, falling back to whoever approved the order).
model StaffFeedback {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  staffId     String   @map("staff_id")
  rating      Int      // 1–5 stars
  isComplaint Boolean  @default(false) @map("is_complaint")
  // 'LIVE' = guest-reported mid-meal (guest picked the staff themselves);
  // 'SETTLE' = post-payment rating (staff resolved automatically from who served)
  source      String   @default("SETTLE") @map("source")
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  staff User  @relation("RatedStaff", fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([createdAt])
  @@index([orderId])
  @@map("staff_feedback")
}

// ─────────────────────────────────────────────
// BOOKINGS
// ─────────────────────────────────────────────

model Booking {
  id                String        @id @default(uuid())
  customerId        String?       @map("customer_id")
  tableId           String?       @map("table_id")
  partySize         Int           @map("party_size")
  slotDate          DateTime      @db.Date @map("slot_date")
  slotTime          String        @map("slot_time")
  slotExpiresAt     DateTime?     @map("slot_expires_at")
  status            BookingStatus @default(PENDING)
  idempotencyKey    String        @unique @map("idempotency_key")
  notes             String?
  seatingPreference String?       @map("seating_preference")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  customer    User?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  table       RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)
  preOrders   Order[]

  @@unique([tableId, slotDate, slotTime])
  @@index([customerId, slotDate])
  @@index([slotDate, status])
  @@index([status])
  @@map("bookings")
}

model CustomerStrike {
  id             String    @id @default(uuid())
  customerId     String    @unique @map("customer_id")
  noShowCount    Int       @default(0) @map("no_show_count")
  lastNoShowAt   DateTime? @map("last_no_show_at")
  blockedUntil   DateTime? @map("blocked_until")
  cancelCount24h Int       @default(0) @map("cancel_count_24h")
  isFlagged      Boolean   @default(false) @map("is_flagged")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_strikes")
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

// Generated by cron at midnight — fast reads for the analytics dashboard
model DailyReport {
  id              String   @id @default(uuid())
  date            DateTime @unique @db.Date
  totalOrders     Int      @map("total_orders")
  cancelledOrders Int      @default(0) @map("cancelled_orders")
  totalCovers     Int      @default(0) @map("total_covers")
  grossRevenue    Decimal  @db.Decimal(12, 2) @map("gross_revenue")
  vatCollected    Decimal  @db.Decimal(12, 2) @map("vat_collected")
  discountGiven   Decimal  @default(0) @db.Decimal(12, 2) @map("discount_given")
  netRevenue      Decimal  @db.Decimal(12, 2) @map("net_revenue")
  cashRevenue     Decimal  @db.Decimal(12, 2) @map("cash_revenue")
  cardRevenue     Decimal  @db.Decimal(12, 2) @map("card_revenue")
  avgOrderValue   Decimal  @db.Decimal(10, 2) @map("avg_order_value")
  avgPrepTimeMins Decimal? @db.Decimal(6, 2) @map("avg_prep_time_mins")
  avgRating       Decimal? @db.Decimal(3, 2) @map("avg_rating")
  peakHour        Int?     @map("peak_hour")
  topItemId       String?  @map("top_item_id")
  generatedAt     DateTime @default(now()) @map("generated_at")

  @@map("daily_reports")
}

// ─────────────────────────────────────────────
// RESTAURANT CONFIG
// ─────────────────────────────────────────────

model RestaurantSettings {
  id                  String   @id @default(uuid())
  restaurantName      String   @default("Al Manzil") @map("restaurant_name")
  restaurantNameAr    String?  @map("restaurant_name_ar")
  tagline             String?
  taglineAr           String?  @map("tagline_ar")
  heroConfig          Json?    @map("hero_config")
  phone               String?
  address             String?
  logoUrl             String?  @map("logo_url")
  openTime            String   @default("00:00") @map("open_time")
  closeTime           String   @default("00:00") @map("close_time")
  weeklySchedule      Json     @default("{\"MON\":{\"open\":true,\"shifts\":[{\"openTime\":\"00:00\",\"closeTime\":\"00:00\"}]},\"TUE\":{\"open\":true,\"shifts\":[{\"openTime\":\"00:00\",\"closeTime\":\"00:00\"}]},\"WED\":{\"open\":true,\"shifts\":[{\"openTime\":\"00:00\",\"closeTime\":\"00:00\"}]},\"THU\":{\"open\":true,\"shifts\":[{\"openTime\":\"00:00\",\"closeTime\":\"00:00\"}]},\"FRI\":{\"open\":true,\"shifts\":[{\"openTime\":\"00:00\",\"closeTime\":\"00:00\"}]},\"SAT\":{\"open\":true,\"shifts\":[{\"openTime\":\"00:00\",\"closeTime\":\"00:00\"}]},\"SUN\":{\"open\":true,\"shifts\":[{\"openTime\":\"00:00\",\"closeTime\":\"00:00\"}]}}") @map("weekly_schedule")
  timezone            String   @default("Asia/Dubai")
  defaultCapacity     Int      @default(4) @map("default_capacity")
  vatRate             Decimal  @default(0.05) @db.Decimal(5, 4) @map("vat_rate")
  serviceChargeRate   Decimal  @default(0) @db.Decimal(5, 4) @map("service_charge_rate")
  // Takeaway packing charge — flat AED per takeaway order (0 = disabled)
  packingCharge       Decimal  @default(0) @db.Decimal(10, 2) @map("packing_charge")
  // Minutes a paid+cancelled order waits before being auto-flagged for refund approval
  refundCoolingMins   Int      @default(10) @map("refund_cooling_mins")
  // Guest free-cancel window: orders held from kitchen during this time; card refunds automatic. 0 = off
  selfCancelWindowMins Int     @default(5) @map("self_cancel_window_mins")
  currency            String   @default("AED")
  currencySymbol      String   @default("AED") @map("currency_symbol")
  defaultPrepTimeMins Int      @default(15) @map("default_prep_time_mins")
  bookingsEnabled          Boolean  @default(true) @map("bookings_enabled")
  slotDurationMins         Int      @default(30) @map("slot_duration_mins")
  expectedDiningMins       Int      @default(90) @map("expected_dining_mins")
  tableReleaseWindowMins   Int      @default(60) @map("table_release_window_mins")
  sameDayCutoffMins        Int      @default(15) @map("same_day_cutoff_mins")
  peakHoursEnabled         Boolean  @default(true) @map("peak_hours_enabled")
  peakRanges               Json     @default("[]") @map("peak_ranges")  // [{start,end}] array of peak time windows
  noShowGracePeriodOffPeak Int      @default(20) @map("no_show_grace_period_off_peak")
  noShowGracePeriodPeak    Int      @default(5) @map("no_show_grace_period_peak")
  maxBookingDaysAhead      Int      @default(7) @map("max_booking_days_ahead")
  requireLoginToBook  Boolean  @default(true) @map("require_login_to_book")
  remindersEnabled    Boolean  @default(false) @map("reminders_enabled")
  reminderMinsBefore  Int      @default(60) @map("reminder_mins_before")
  brandPreset         String   @default("amber") @map("brand_preset")
  brandColor          String   @default("#f59e0b") @map("brand_color")
  showLanguageToggle  Boolean  @default(false) @map("show_language_toggle")
  loginDesktopImage   String?  @map("login_desktop_image")
  loginMobileImage    String?  @map("login_mobile_image")
  vatNumber           String?  @map("vat_number")
  billConfig          Json?    @map("bill_config")
  kotConfig           Json?    @map("kot_config")
  // Payment & order feature flags
  splitPaymentEnabled Boolean  @default(true)  @map("split_payment_enabled")
  tipEnabled          Boolean  @default(true)  @map("tip_enabled")
  discountEnabled     Boolean  @default(true)  @map("discount_enabled")
  preOrderEnabled        Boolean  @default(true)  @map("pre_order_enabled")
  preOrderLeadMins       Int      @default(30)    @map("pre_order_lead_mins")
  kdsEnabled             Boolean  @default(false) @map("kds_enabled")
  thermalEnabled         Boolean  @default(false) @map("thermal_enabled")
  thermalPrinterIp    String?  @map("thermal_printer_ip")
  thermalPrinterPort  Int      @default(9100) @map("thermal_printer_port")
  // Email — SMTP + global sender identity
  smtpHost            String?  @map("smtp_host")
  smtpPort            Int      @default(465) @map("smtp_port")
  smtpSecure          Boolean  @default(true) @map("smtp_secure")
  smtpUser            String?  @map("smtp_user")
  smtpPass            String?  @map("smtp_pass")
  emailFromName       String?  @map("email_from_name")
  emailFromAddress    String?  @map("email_from_address")
  emailReplyTo        String?  @map("email_reply_to")
  supportEmail        String?  @map("support_email")
  supportPhone        String?  @map("support_phone")
  // Social presence — { instagram?, whatsapp?, telegram?, tiktok?, facebook?, twitter? }
  // Keys present → shown in email footers + login/landing pages
  socialLinks         Json?    @map("social_links")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("restaurant_settings")
}

// ─────────────────────────────────────────────
// EMAIL TEMPLATES
// ─────────────────────────────────────────────

model EmailTemplate {
  id            String   @id @default(uuid())
  key           String   @unique   // 'booking_confirmation' | 'booking_cancelled' | 'order_cancelled' | 'otp' | 'welcome'
  name          String             // display name in settings UI
  subject       String             // supports {{restaurantName}}, {{ref}}, {{name}}, etc.
  fromName      String?  @map("from_name")      // null = use global emailFromName
  replyTo       String?  @map("reply_to")       // null = use global emailReplyTo
  enabled       Boolean  @default(true)
  localeEnabled Boolean  @default(false) @map("locale_enabled")  // show AR/EN switcher for this template
  bgColor       String   @default("#f0f0f0") @map("bg_color")
  cardTheme     String   @default("light") @map("card_theme")    // 'light' | 'dark'
  footerNote    String?  @map("footer_note")
  // Localizable no-reply footer line — editable in settings, shown in email footer
  footerNoReply   String?  @map("footer_no_reply")
  footerNoReplyAr String?  @map("footer_no_reply_ar")
  // Optional custom greeting override
  greeting        String?
  greetingAr      String?  @map("greeting_ar")
  // Extensible per-template config — social overrides, custom CTAs, A/B data, etc.
  metadata      Json?
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("email_templates")
}

// Seasonal / promotional offers — time-boxed discounts applied automatically at order time.
// scope: 'ALL' (whole menu), 'CATEGORY' (categoryIds), or 'ITEM' (itemIds)
// type: 'PERCENT' (value = % off, e.g. 20) or 'FIXED' (value = flat AED off per matching item)
model Offer {
  id           String   @id @default(uuid())
  name         String
  nameAr       String?  @map("name_ar")
  scope        String   @default("ALL") // ALL | CATEGORY | ITEM
  categoryIds  String[] @default([]) @map("category_ids")
  itemIds      String[] @default([]) @map("item_ids")
  type         String   @default("PERCENT") // PERCENT | FIXED
  value        Decimal  @db.Decimal(10, 2)
  startsAt     DateTime @map("starts_at")
  endsAt       DateTime @map("ends_at")
  isActive     Boolean  @default(true) @map("is_active")
  bannerText   String?  @map("banner_text")
  bannerTextAr String?  @map("banner_text_ar")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, startsAt, endsAt])
  @@map("offers")
}

// Web Push subscriptions — one row per browser/device that opted in
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?  @map("user_id")
  role      String   @default("STAFF") // STAFF | CUSTOMER — who gets which notification kinds
  createdAt DateTime @default(now()) @map("created_at")

  @@map("push_subscriptions")
}
